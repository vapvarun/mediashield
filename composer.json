{
    "name": "mediashield/mediashield",
    "description": "Video protection for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "MediaShield\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MediaShield\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "woocommerce/action-scheduler": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "composer/*": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "find includes -name '*.php' -not -path '*/vendor/*' -not -path '*/node_modules/*' -print0 | xargs -0 -n1 -P4 php -l | (! grep -v 'No syntax errors detected')",
        "phpcs": "phpcs --standard=phpcs.xml --runtime-set ignore_warnings_on_exit 1",
        "phpcbf": "phpcbf --standard=phpcs.xml",
        "phpstan": "phpstan analyse --memory-limit=2G --no-progress",
        "check": [
            "@lint",
            "@phpcs",
            "@phpstan"
        ]
    },
    "scripts-descriptions": {
        "lint": "PHP syntax check (parallelized) across all includes/*.php files.",
        "phpcs": "WordPress Coding Standards check (errors block, warnings pass).",
        "phpcbf": "Auto-fix WPCS issues where possible.",
        "phpstan": "Static analysis at level 5 with WordPress stubs.",
        "check": "Run the full local gate: lint + phpcs + phpstan. Required before push."
    }
}
