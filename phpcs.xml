<?xml version="1.0"?>
<ruleset name="MediaShield">
	<description>WordPress Coding Standards for MediaShield plugin.</description>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Scan plugin source -->
	<file>.</file>

	<!-- Exclude non-source directories -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>
	<exclude-pattern>dist/*</exclude-pattern>
	<exclude-pattern>tests/*</exclude-pattern>
	<exclude-pattern>plan/*</exclude-pattern>

	<!-- WordPress standard -->
	<rule ref="WordPress">
		<!-- PSR-4 PHP 8.1+ namespaced — file naming not applicable -->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

		<!-- Modern PHP short arrays and ternary -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<exclude name="WordPress.PHP.DisallowShortTernary"/>

		<!-- Yoda conditions not required -->
		<exclude name="WordPress.PHP.YodaConditions"/>

		<!-- Allow non-prefixed variables in namespaced code -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>

		<!-- Global variables override — common in WP bootstrap -->
		<exclude name="WordPress.WP.GlobalVariablesOverride"/>

		<!-- Direct DB queries are intentional for custom tables -->
		<exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
		<exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
		<exclude name="WordPress.DB.DirectDatabaseQuery.SchemaChange"/>
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQLPlaceholders.MissingReplacements"/>

		<!-- Comment style — not enforced for PSR-4 code -->
		<exclude name="Squiz.Commenting.FileComment"/>
		<exclude name="Squiz.Commenting.FunctionComment"/>
		<exclude name="Squiz.Commenting.ClassComment"/>
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
		<exclude name="Squiz.Commenting.InlineComment.SpacingAfter"/>
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>

		<!-- Translators comment not required -->
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
	</rule>

	<!-- KEEP all security sniffs enforced:
	     WordPress.Security.EscapeOutput
	     WordPress.Security.NonceVerification
	     WordPress.Security.ValidatedSanitizedInput
	-->

	<!-- Set text domain -->
	<config name="text_domain" value="mediashield"/>

	<!-- Set prefixes -->
	<config name="prefixes" value="mediashield,ms_,MediaShield"/>

	<!-- Minimum WordPress version -->
	<config name="minimum_wp_version" value="6.5"/>
</ruleset>
